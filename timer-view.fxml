<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx"
            fx:controller="application.TimerController">

    <!-- TOP -->

    <top>

        <HBox alignment="CENTER_LEFT" spacing="20">

            <padding>
                <Insets top="15"
                        right="15"
                        bottom="15"
                        left="15"/>
            </padding>

            <Label text="Focus Flow Timer">

                <font>
                    <Font size="24"/>
                </font>

            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="currentTimeLabel"
                   text="00:00:00"/>

        </HBox>

    </top>

    <!-- LEFT -->

    <left>

        <VBox spacing="10">

            <padding>
                <Insets top="15"
                        right="15"
                        bottom="15"
                        left="15"/>
            </padding>

            <Label text="Tasks">

                <font>
                    <Font size="18"/>
                </font>

            </Label>

            <TextField fx:id="taskField"
                       promptText="Task name"/>

            <TextField fx:id="rewardField"
                       promptText="Reward minutes"/>

            <HBox spacing="10">

                <Button text="Add"
                        onAction="#addTask"/>

                <Button text="Done"
                        onAction="#completeTask"/>

                <Button text="Delete"
                        onAction="#deleteTask"/>

            </HBox>

            <ListView fx:id="taskList"
                      prefWidth="250"
                      VBox.vgrow="ALWAYS"/>

        </VBox>

    </left>

    <!-- CENTER -->

    <center>

        <VBox alignment="CENTER"
              spacing="20">

            <Label fx:id="modeLabel"
                   text="FOCUS MODE">

                <font>
                    <Font size="20"/>
                </font>

            </Label>

            <Label fx:id="sessionLabel"
                   text="Session #1">

                <font>
                    <Font size="18"/>
                </font>

            </Label>

            <Label fx:id="timerLabel"
                   text="25:00">

                <font>
                    <Font size="64"/>
                </font>

            </Label>

            <ProgressBar fx:id="progressBar"
                         prefWidth="300"/>

            <HBox spacing="10"
                   alignment="CENTER">

                <Button text="Start"
                        onAction="#startTimer"/>

                <Button text="Pause"
                        onAction="#pauseTimer"/>

                <Button text="Reset"
                        onAction="#resetTimer"/>

            </HBox>

            <HBox spacing="25"
                   alignment="CENTER">

                <VBox alignment="CENTER"
                       spacing="5">

                    <Label text="Focus"/>

                    <Spinner fx:id="studySpinner"/>

                </VBox>

                <VBox alignment="CENTER"
                       spacing="5">

                    <Label text="Break"/>

                    <Spinner fx:id="breakSpinner"/>

                </VBox>

            </HBox>

            <Label fx:id="breakBankLabel"
                   text="Break Bank: 0 min">

                <font>
                    <Font size="18"/>
                </font>

            </Label>

        </VBox>

    </center>

</BorderPane>
